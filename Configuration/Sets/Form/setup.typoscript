plugin.tx_form {
  handlebars {
    FormFrontend {
      templateName = Render
      templateRootPaths {
        20 = EXT:handlebars_forms/Resources/Private/Templates/Form
      }
    }
  }

  handlebarsForms {
    default {
      templateName = {$plugin.tx_handlebarsforms.view.templateName}
    }
  }
}
